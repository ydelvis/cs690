{
  "service": "go-todo",
  "provider": {
    "name": "aws",
    "runtime": "go1.x",
    "region": "ap-northeast-2",
    "stage": "dev",
    "memory_mb": null,
    "timeout_s": null
  },
  "environment": {
    "DYNAMO_REGION": "${file(./.go-serverless-demo.yml):DYNAMO_REGION}",
    "DYNAMO_TABLE_NAME": "${file(./.go-serverless-demo.yml):DYNAMO_TABLE_NAME}"
  },
  "functions": {
    "rest": {
      "handler": "bin/rest",
      "runtime": "go1.x",
      "environment": {},
      "events": [
        {
          "http": {
            "path": "/{proxy+}",
            "method": "ANY",
            "cors": true
          }
        },
        {
          "http": {
            "path": "/{proxy+}",
            "method": "OPTIONS",
            "cors": true
          }
        }
      ]
    }
  },
  "iam_statements": [],
  "custom": {
    "apigwBinary": {
      "types": [
        "application/json",
        "text/html"
      ]
    }
  },
  "source_files": [
    "serverless.yml"
  ]
}